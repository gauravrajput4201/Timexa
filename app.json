{
  "expo": {
    "name": "Timexa",
    "slug": "Timexa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brandLogo.png",
    "scheme": "timexa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gauravsingh420.Timexa"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAFAFA",
        "foregroundImage": "./assets/images/brandLogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gauravsingh420.Timexa"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/brandLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/brandLogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAFA"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d27bded0-dd92-4d07-8e91-5b4cb6156431"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d27bded0-dd92-4d07-8e91-5b4cb6156431"
    }
  }
}
